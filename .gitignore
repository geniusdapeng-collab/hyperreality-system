characters/
stories/
productions/
.trash/
temp/
tmp/
output/
logs/
checkpoints/
debug_llm/
*.log

# 大文件类型（不推送）
*.zip
*.tar.gz
*.rar
*.7z
*.mp4
*.mov
*.avi
*.mkv
*.mp3
*.wav
*.flac
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.psd
*.ai
*.pdf

# 依赖和构建产物（不推送）
node_modules/
dist/
build/
*.exe
*.dll
*.so
*.dylib

# 环境配置（不推送）
.env
.env.local
.env.*.local
*.pem
*.key

# 操作系统文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 测试数据（可选）
test-data/
fixtures/
*.test.json
*.mock.json

# 废弃脚本（不推送）
_deprecated_scripts/

# 运行时输出（不推送）
preproduction-*.json
checkpoint-*.json
