# Hyperreal AI Video System (HAVS) — 环境变量配置模板

# ==========================================
# 火山引擎 Seedance API 配置（必需）
# ==========================================
# 获取方式: https://console.volcengine.com/ark/
VOLCENGINE_ARK_API_KEY=your_volcengine_api_key_here

# 接入点配置（可选，系统有默认值）
# SEEDANCE_ENDPOINT=ep-your-endpoint-id
# SEEDREAM_ENDPOINT=ep-your-image-endpoint-id

# ==========================================
# LLM 模型配置（可选）
# ==========================================
# 默认使用 kimi-k2p6，可通过环境变量覆盖
# DEFAULT_LLM_MODEL=kimi-k2p6

# ==========================================
# 可选：其他服务配置
# ==========================================
# 如需接入其他渲染服务，在此配置
# CUSTOM_RENDER_API_KEY=your_key_here
# CUSTOM_RENDER_BASE_URL=https://api.example.com
