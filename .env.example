# 超现实系统环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# 火山引擎 API 配置（必需）
# ============================================
VOLCENGINE_ARK_API_KEY=your_api_key_here
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Seedance 接入点
SEEDANCE_ENDPOINT=ep-20260518004622-jp46s
SEEDANCE_FAST_ENDPOINT=ep-20260518003432-n8v8f

# Seedream 接入点
SEEDREAM_ENDPOINT=ep-20260518004750-lz76f

# ============================================
# 日志配置
# ============================================
# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 生产环境建议设置为 warn
# LOG_LEVEL=warn

# ============================================
# 超时配置（可选，使用默认值可不填）
# 单位: 毫秒
# ============================================
# HYPERREALITY_TIMEOUT_LLM_SHORT=180000
# HYPERREALITY_TIMEOUT_LLM_MEDIUM=300000
# HYPERREALITY_TIMEOUT_LLM_LONG=600000
# HYPERREALITY_TIMEOUT_RENDER_MEDIUM=300000
# HYPERREALITY_TIMEOUT_SYSTEM_BUDGET=1800000

# ============================================
# 内存配置
# ============================================
# Node.js 内存限制（MB）
# NODE_OPTIONS=--max-old-space-size=4096

# ============================================
# 角色目录
# ============================================
CHARACTERS_DIR=./characters

# ============================================
# 输出目录
# ============================================
OUTPUT_DIR=./output
